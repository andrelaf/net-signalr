{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.SignalR": "Information",
      "Microsoft.AspNetCore.Http.Connections": "Information"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Data Source=workspace.db"
  },
  "Jwt": {
    "Issuer": "SignalRDemo",
    "Audience": "SignalRDemo.Client",
    "SigningKey": "dev-only-super-secret-signing-key-change-me-please-32+chars",
    "ExpiryMinutes": 120
  },
  "Cors": {
    "ClientOrigins": [ "http://localhost:5173", "https://localhost:5173" ]
  },
  "SignalR": {
    "Backplane": "None",
    "RedisConnection": "localhost:6379"
  },
  "Sla": {
    "BreachAfterHours": 24,
    "PollSeconds": 30
  }
}
